APP_ENV=local
DATABASE_URL=postgresql://aiops:aiops@postgres:5432/aiops
LOCAL_DATABASE_URL=postgresql://aiops:aiops@localhost:5432/aiops
OLLAMA_BASE_URL=http://ollama:11434

# PET target-host capabilities are opt-in and disabled unless set to true.
PET_ENABLE_BROWSER_NAVIGATION=false
PET_ENABLE_MUSIC_LIBRARY=false
PET_ENABLE_MUSIC_PLAYBACK=false
PET_ENABLE_DEVICE_MODEL_CHAT=false
# Optional; defaults to the current user's bounded Music directory.
PET_MUSIC_LIBRARY_ROOT=
# Device-model chat is loopback-only and never falls back to a cloud model.
PET_DEVICE_OLLAMA_BASE_URL=http://127.0.0.1:11434
PET_DEVICE_OLLAMA_MODEL=device-default
PET_DEVICE_OLLAMA_TIMEOUT_SECONDS=60
OPENWEBUI_URL=http://open-webui:8080
N8N_URL=https://aioperation.app.n8n.cloud
LOCAL_N8N_URL=http://n8n:5678
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
FLOWISE_URL=https://cloud.flowiseai.com
LOCAL_FLOWISE_URL=http://localhost:3001
FLOWISE_API_KEY=
WORKER_MACHINE_ID=brain-gaming-pc
WORKER_SLEEP_SECONDS=2
AI_OPS_QUEUE_STEWARD_ENABLED=true
AI_OPS_QUEUE_STEWARD_SECONDS=2
REPORT_TIMEZONE=America/Chicago
GITHUB_OWNER=bluejay88
GITHUB_REPO=AI-Operations-center
GITHUB_DEFAULT_BRANCH=master
GITHUB_REPO_URL=https://github.com/bluejay88/AI-Operations-center.git
NETLIFY_AUTH_TOKEN=
TAILSCALE_HOSTNAME=
BRAIN_HOST=100.70.49.32
HUMAN_APPROVAL_REQUIRED=true
